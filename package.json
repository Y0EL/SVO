{
  "name": "svo-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SVO MCP server with synthetic product, order, ads, and WhatsApp systems for PRD validation.",
  "scripts": {
    "generate:fixtures": "node scripts/generate-fixtures.mjs",
    "build": "tsc -p tsconfig.json && node scripts/copy-data.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
